{
  "name": "@landing/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./styles.css": "./src/styles.css",
    "./pixel-blast": "./src/pixel-blast/index.ts",
    "./soft-aurora": "./src/soft-aurora/index.ts",
    "./logo-loop": "./src/logo-loop/index.ts",
    "./lib/types": "./src/lib/types.ts",
    "./card": "./src/card.tsx",
    "./gradient": "./src/gradient.tsx",
    "./turborepo-logo": "./src/turborepo-logo.tsx"
  },
  "license": "MIT",
  "scripts": {
    "build": "tailwindcss -i ./src/styles.css -o ./dist/index.css",
    "build:components": "tsc",
    "check-types": "tsc --noEmit",
    "dev": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "ogl": "^1.0.11",
    "postprocessing": "^6.39.1",
    "three": "^0.184.0"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@landing/eslint-config": "workspace:*",
    "@landing/tailwind-config": "workspace:*",
    "@landing/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.1.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.184.1",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.1.5",
    "typescript": "5.9.2"
  }
}
